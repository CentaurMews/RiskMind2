{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seed/prebuilt-templates": "./src/seed/prebuilt-templates.ts"
  },
  "scripts": {
    "bootstrap": "tsx ./src/bootstrap.ts",
    "push": "tsx ./src/bootstrap.ts && drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "tsx ./src/bootstrap.ts && drizzle-kit push --force --config ./drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
