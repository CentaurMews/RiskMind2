# RiskMind Server Environment Variables
# Copy this file to .env and fill in actual values

# Server port — Express listens on this port
PORT=4000

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://riskmind:CHANGE_ME@localhost:5432/riskmind

# JWT secret for signing auth tokens — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME_generate_random_base64_string

# AES-256-GCM encryption key for vendor API keys
# MUST be exactly 32 bytes base64-encoded (44 chars) — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=CHANGE_ME_generate_32_bytes_base64
